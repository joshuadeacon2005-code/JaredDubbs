---
const currentPath = Astro.url.pathname;

const services = [
  { name: 'ADHD & Neurodivergence', href: '/services/adhd' },
  { name: 'ASD & Autism', href: '/services/asd' },
  { name: 'LGBTQ+ Counselling', href: '/services/lgbtq' },
  { name: 'Individual Counselling', href: '/services/individual' },
  { name: 'Couples & Parent-Teen', href: '/services/couples' },
  { name: 'Group Therapy', href: '/services/group' },
  { name: 'DBT Therapy', href: '/services/dbt' },
];

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Services', href: '/services', children: services },
  { name: 'About', href: '/about' },
  { name: 'Blog', href: '/blog' },
  { name: 'Prices & FAQ', href: '/prices' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-[var(--color-bg)]/95 backdrop-blur-sm border-b border-[var(--color-bg-alt)]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="relative flex items-center justify-between h-22">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline shrink-0" aria-label="Jared Dubbs Counselling — Home">
        <img src="/images/logo-icon.png" alt="" width="80" height="62" class="w-20 h-auto" />
        <div class="hidden sm:flex flex-col leading-tight">
          <span class="font-semibold text-[var(--color-secondary)] text-xl tracking-tight" style="font-family: var(--font-serif)">Jared Dubbs</span>
          <span class="text-[var(--color-text-light)] text-xs tracking-[0.15em] uppercase">Counselling</span>
        </div>
      </a>

      <!-- Desktop Nav — centered -->
      <ul class="hidden lg:flex items-center gap-1 absolute left-1/2 -translate-x-1/2" role="list">
        {navLinks.map((link) => (
          <li class="relative group">
            <a
              href={link.href}
              class={`px-4 py-2 rounded-[var(--radius-sm)] text-[var(--text-sm)] font-medium no-underline transition-colors ${
                isActive(link.href)
                  ? 'text-[var(--color-primary)] bg-[var(--color-bg-alt)]'
                  : 'text-[var(--color-text)] hover:text-[var(--color-primary)] hover:bg-[var(--color-bg-alt)]'
              }`}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.name}
              {link.children && (
                <svg class="inline-block ml-1 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.children && (
              <ul class="absolute left-0 top-full mt-1 w-64 bg-white rounded-[var(--radius)] shadow-lg border border-[var(--color-bg-alt)] py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" role="list">
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`block px-4 py-2.5 text-[var(--text-sm)] no-underline transition-colors ${
                        isActive(child.href)
                          ? 'text-[var(--color-primary)] bg-[var(--color-bg-alt)]'
                          : 'text-[var(--color-text)] hover:text-[var(--color-primary)] hover:bg-[var(--color-bg-alt)]'
                      }`}
                    >
                      {child.name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <!-- Right side: Social icons (desktop) + Book Now + mobile hamburger -->
      <div class="flex items-center gap-2">
        <!-- WhatsApp — desktop only; mobile users get this in the burger menu -->
        <a
          href="https://wa.me/85257753743?text=Hi%20Jared%2C%20I%27d%20like%20to%20enquire%20about%20counselling."
          target="_blank"
          rel="noopener noreferrer"
          class="nav-social hidden lg:flex items-center gap-0 rounded-[var(--radius-full)] bg-[#25D366] text-white no-underline transition-all duration-300 w-9 h-9 justify-center overflow-hidden"
          aria-label="Message Jared on WhatsApp"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span class="nav-social-label max-w-0 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-300 text-xs font-semibold">WhatsApp</span>
          <span class="nav-social-sub max-w-0 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-300 text-white/70 text-xs font-normal">— message Jared</span>
        </a>
        <!-- LinkedIn — desktop only -->
        <a
          href="https://www.linkedin.com/in/jareddubbs/"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-social hidden lg:flex items-center gap-0 rounded-[var(--radius-full)] bg-[#0A66C2] text-white no-underline transition-all duration-300 w-9 h-9 justify-center overflow-hidden"
          aria-label="Connect with Jared on LinkedIn"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="nav-social-label max-w-0 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-300 text-xs font-semibold">LinkedIn</span>
          <span class="nav-social-sub max-w-0 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-300 text-white/70 text-xs font-normal">— connect with Jared</span>
        </a>

        <!-- Book Now CTA — visible on desktop -->
        <a
          href="/book"
          class="hidden lg:inline-flex items-center gap-1.5 px-4 py-2 ml-1 rounded-[var(--radius-sm)] bg-[var(--color-primary)] text-white text-[var(--text-sm)] font-semibold no-underline hover:bg-[var(--color-primary-hover)] transition-colors"
          aria-label="Book a discovery call"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Book Now
        </a>

        <!-- Book Now CTA — compact, visible on mobile only -->
        <a
          href="/book"
          class="lg:hidden inline-flex items-center gap-1.5 px-3.5 py-2.5 rounded-[var(--radius-sm)] bg-[var(--color-primary)] text-white text-[var(--text-sm)] font-semibold no-underline hover:bg-[var(--color-primary-hover)] transition-colors min-h-[40px]"
          aria-label="Book a free discovery call"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Book Free Call
        </a>

        <!-- Mobile: Hamburger -->
        <div class="lg:hidden">
        <button
          type="button"
          id="mobile-menu-btn"
          class="p-2 rounded-[var(--radius-sm)] text-[var(--color-text)] hover:bg-[var(--color-bg-alt)] min-w-[44px] min-h-[44px] flex items-center justify-center"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 top-[72px] bg-white z-40 hidden overflow-y-auto" role="dialog" aria-label="Mobile navigation">
    <nav class="px-6 py-8" aria-label="Mobile navigation">
      <a
        href="/book"
        class="flex items-center justify-center gap-2 mb-6 px-4 py-3 rounded-[var(--radius-sm)] bg-[var(--color-primary)] text-white font-semibold no-underline min-h-[44px]"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Book Now — free 15-min discovery call
      </a>
      <ul class="space-y-2" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`block px-4 py-3 rounded-[var(--radius-sm)] font-medium no-underline text-lg min-h-[44px] ${
                isActive(link.href)
                  ? 'text-[var(--color-primary)] bg-[var(--color-bg-alt)]'
                  : 'text-[var(--color-text)] hover:bg-[var(--color-bg-alt)]'
              }`}
            >
              {link.name}
            </a>
            {link.children && (
              <ul class="ml-4 mt-1 space-y-1" role="list">
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class={`block px-4 py-2.5 rounded-[var(--radius-sm)] no-underline min-h-[44px] flex items-center ${
                        isActive(child.href)
                          ? 'text-[var(--color-primary)] bg-[var(--color-bg-alt)]'
                          : 'text-[var(--color-text-light)] hover:text-[var(--color-primary)] hover:bg-[var(--color-bg-alt)]'
                      }`}
                    >
                      {child.name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <!-- Social links inside the mobile menu (mirrors the desktop nav icons) -->
      <div class="mt-8 pt-6 border-t border-[var(--color-bg-alt)] flex gap-3">
        <a
          href="https://wa.me/85257753743?text=Hi%20Jared%2C%20I%27d%20like%20to%20enquire%20about%20counselling."
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-[var(--radius-sm)] bg-[#25D366] text-white font-semibold no-underline min-h-[44px]"
          aria-label="Message Jared on WhatsApp"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href="https://www.linkedin.com/in/jareddubbs/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 rounded-[var(--radius-sm)] bg-[#0A66C2] text-white font-semibold no-underline min-h-[44px]"
          aria-label="Connect with Jared on LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .nav-social {
    position: relative;
    transition: padding 0.3s ease, gap 0.3s ease;
    /* Invisible extended hit area to prevent flicker */
  }
  .nav-social::after {
    content: '';
    position: absolute;
    inset: -4px -8px;
  }
  .nav-social:hover {
    width: auto;
    padding: 0.375rem 0.75rem;
    gap: 0.375rem;
  }
  .nav-social .nav-social-label,
  .nav-social .nav-social-sub {
    transition: max-width 0.3s ease, opacity 0.2s ease 0.05s;
  }
  .nav-social:hover .nav-social-label {
    max-width: 80px;
    opacity: 1;
  }
  .nav-social:hover .nav-social-sub {
    max-width: 160px;
    opacity: 1;
    margin-left: 2px;
  }
</style>
