---
type TrustItem = string | { label: string; href?: string };

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCta?: string;
  secondaryCtaLink?: string;
  showTrustBar?: boolean;
  trustItems?: TrustItem[];
  showPhoto?: boolean;
  photoSrc?: string;
  photoAlt?: string;
  bgImage?: string;
  bgColor?: 'default' | 'alt';
  compact?: boolean;
}

function trustParts(item: TrustItem): { label: string; href?: string } {
  return typeof item === 'string' ? { label: item } : item;
}

const {
  title,
  subtitle,
  ctaText = 'Book a Free Discovery Call',
  ctaLink = '/book',
  secondaryCta,
  secondaryCtaLink,
  showTrustBar = false,
  trustItems = [],
  showPhoto = false,
  photoSrc = '/images/jared-headshot-sm.jpg',
  photoAlt = 'Jared Dubbs, counsellor in Central Hong Kong',
  bgImage,
  bgColor = 'default',
  compact = false,
} = Astro.props;

const isFullBleed = !!bgImage;
const paddingClass = compact ? 'py-16 md:py-20' : 'py-16 md:py-36';
---

{isFullBleed ? (
  <!-- Full-bleed image hero -->
  <section class="relative overflow-hidden">
    <img
      src={bgImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-[78%_center] md:object-top"
      loading="eager"
    />
    {/* Stronger overlay on mobile so the headline stays readable when Jared's face is under the text */}
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-secondary)]/85 via-[var(--color-secondary)]/70 to-[var(--color-secondary)]/60 md:bg-gradient-to-r md:from-[var(--color-secondary)]/90 md:via-[var(--color-secondary)]/70 md:to-[var(--color-secondary)]/40"></div>

    {/* Credentials banner — full width across the top */}
    {showTrustBar && trustItems.length > 0 && (
      <div class="relative bg-black/10 backdrop-blur-[2px] border-b border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-center gap-5 md:gap-8 flex-wrap">
          {trustItems.map((raw) => {
            const { label, href } = trustParts(raw);
            const inner = (
              <>
                <svg class="w-4 h-4 text-[var(--color-gold)] shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {label}
              </>
            );
            return href ? (
              <a
                href={href}
                class="trust-link flex items-center gap-2 text-white/90 text-xs md:text-sm font-medium tracking-wide uppercase no-underline hover:text-white hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-gold)] rounded-sm transition-colors"
              >
                {inner}
              </a>
            ) : (
              <span class="flex items-center gap-2 text-white/90 text-xs md:text-sm font-medium tracking-wide uppercase">
                {inner}
              </span>
            );
          })}
        </div>
      </div>
    )}

    <div class={`relative ${paddingClass}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-3">
          <h1 class="text-white mb-8 text-4xl md:text-5xl lg:text-6xl leading-[1.1]" set:html={title} />
          {subtitle && <p class="text-white/75 text-base md:text-lg mb-10 leading-relaxed max-w-xl" style="font-family: var(--font-sans)">{subtitle}</p>}

          <div class="flex flex-wrap gap-4">
            {ctaText && (
              <a
                href={ctaLink}
                class="inline-flex items-center px-7 py-4 bg-[var(--color-gold)] text-white font-semibold rounded-[var(--radius)] no-underline hover:bg-[var(--color-gold-light)] transition-colors min-h-[44px] text-lg"
              >
                {ctaText}
              </a>
            )}
            {secondaryCta && secondaryCtaLink && (
              <a
                href={secondaryCtaLink}
                class="inline-flex items-center px-7 py-4 border-2 border-white/40 text-white font-semibold rounded-[var(--radius)] no-underline hover:bg-white/10 transition-colors min-h-[44px]"
              >
                {secondaryCta}
              </a>
            )}
          </div>
        </div>

        {showPhoto && (
          <div class="hidden lg:flex lg:col-span-2 justify-center">
            <img
              src={photoSrc}
              alt={photoAlt}
              width="360"
              height="450"
              class="rounded-[var(--radius-lg)] shadow-2xl ring-2 ring-white/10 max-w-full h-auto"
              loading="eager"
            />
          </div>
        )}
      </div>
    </div>
    </div>
  </section>
) : (
  <!-- Compact text hero for inner pages -->
  <section class={`${bgColor === 'alt' ? 'bg-[var(--color-bg-alt)]' : 'bg-[var(--color-bg)]'} ${paddingClass}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class={`${showPhoto ? 'grid grid-cols-1 lg:grid-cols-5 gap-12 items-center' : ''}`}>
        <div class={showPhoto ? 'lg:col-span-3' : 'max-w-3xl'}>
          <div class="w-12 h-1 bg-[var(--color-gold)] rounded-full mb-6"></div>
          <h1 class="mb-6 text-3xl md:text-4xl lg:text-5xl leading-[1.15]" set:html={title} />
          {subtitle && <p class="text-[var(--color-text-light)] text-base md:text-lg mb-8 leading-relaxed">{subtitle}</p>}

          <div class="flex flex-wrap gap-4 mb-8">
            {ctaText && (
              <a
                href={ctaLink}
                class="inline-flex items-center px-6 py-3.5 bg-[var(--color-primary)] text-white font-semibold rounded-[var(--radius)] no-underline hover:bg-[var(--color-primary-hover)] transition-colors min-h-[44px]"
              >
                {ctaText}
              </a>
            )}
          </div>

          {showTrustBar && trustItems.length > 0 && (
            <div class="flex flex-wrap gap-x-4 gap-y-2 text-[var(--text-sm)] text-[var(--color-text-light)] reveal-stagger">
              {trustItems.map((raw) => {
                const { label, href } = trustParts(raw);
                const inner = (
                  <>
                    <svg class="w-4 h-4 text-[var(--color-primary)] shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {label}
                  </>
                );
                return href ? (
                  <a
                    href={href}
                    class="reveal-item flex items-center gap-1.5 no-underline text-[var(--color-text-light)] hover:text-[var(--color-primary)] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-primary)] rounded-sm transition-colors"
                  >
                    {inner}
                  </a>
                ) : (
                  <span class="flex items-center gap-1.5 reveal-item">
                    {inner}
                  </span>
                );
              })}
            </div>
          )}
        </div>

        {showPhoto && (
          <div class="lg:col-span-2 flex justify-center">
            <img
              src={photoSrc}
              alt={photoAlt}
              width="400"
              height="500"
              class="rounded-[var(--radius-lg)] shadow-xl ring-1 ring-[var(--color-gold)]/20 max-w-full h-auto"
              loading={compact ? 'lazy' : 'eager'}
            />
          </div>
        )}
      </div>
    </div>
  </section>
)}
