---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  readTime: string;
  date: Date;
  featured?: boolean;
  image?: string;
}

const { title, slug, excerpt, category, readTime, date, featured = false, image: imageProp } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryColors: Record<string, string> = {
  'ADHD': 'bg-amber-500/90 text-white',
  'DBT': 'bg-[var(--color-primary)]/90 text-white',
  'Anxiety & Depression': 'bg-stone-600/90 text-white',
  'Therapy & Wellbeing': 'bg-[var(--color-accent)]/90 text-white',
};

const postImages: Record<string, string> = {
  'adhd-complete-guide': '/images/blog-adhd-complete-guide.jpg',
  'adhd-hong-kong': '/images/blog-adhd-hong-kong.jpg',
  'adhd-relationships': '/images/blog-adhd-relationships.jpg',
  'adhd-vs-anxiety': '/images/blog-adhd-vs-anxiety.jpg',
  'executive-dysfunction': '/images/blog-executive-dysfunction.jpg',
  'what-is-dbt': '/images/blog-what-is-dbt.jpg',
  'dbt-distress-tolerance': '/images/blog-dbt-distress-tolerance.jpg',
  'dbt-emotional-dysregulation': '/images/blog-dbt-emotional-dysregulation.jpg',
  'dbt-vs-cbt': '/images/blog-dbt-vs-cbt.jpg',
  'radical-acceptance': '/images/blog-radical-acceptance.jpg',
  'do-i-need-therapy': '/images/blog-do-i-need-therapy.jpg',
  'first-therapy-session': '/images/blog-first-therapy-session.jpg',
  'anxiety-hong-kong': '/images/blog-anxiety-hong-kong.jpg',
  'lgbtq-therapy-hk': '/images/blog-lgbtq-therapy-hk.jpg',
  'why-therapy-works': '/images/blog-why-therapy-works.jpg',
};

const image = imageProp || postImages[slug] || `/images/blog-${slug}.jpg`;
const imageAlt = `${title} — ${category} article by Jared Dubbs`;
---

{featured ? (
  <a href={`/blog/${slug}`} class="group block relative rounded-2xl overflow-hidden no-underline blog-card">
    <div class="relative h-72 md:h-96 overflow-hidden">
      <img src={image} alt={imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10">
        <div class="flex items-center gap-3 mb-3">
          <span class={`inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full backdrop-blur-sm ${categoryColors[category] || 'bg-gray-600/90 text-white'}`}>
            {category}
          </span>
          <span class="text-white/80 text-xs flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {readTime}
          </span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2 leading-tight group-hover:text-[var(--color-gold-light)] transition-colors" style="font-family: var(--font-serif)">{title}</h2>
        <p class="text-white/75 text-sm line-clamp-2 max-w-2xl mb-3">{excerpt}</p>
        <div class="flex items-center gap-4">
          <time datetime={date.toISOString().split('T')[0]} class="text-xs text-white/60">{formattedDate}</time>
          <span class="text-[var(--color-gold-light)] font-semibold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
            Read article <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </span>
        </div>
      </div>
    </div>
  </a>
) : (
  <a href={`/blog/${slug}`} class="group block rounded-2xl overflow-hidden no-underline blog-card bg-white border border-[var(--color-bg-alt)] hover:border-[var(--color-gold-light)]/40 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5">
    <div class="relative h-52 overflow-hidden">
      <img src={image} alt={imageAlt} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
      <span class={`absolute top-3 left-3 inline-block px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider rounded-full backdrop-blur-sm ${categoryColors[category] || 'bg-gray-600/90 text-white'}`}>
        {category}
      </span>
    </div>
    <div class="p-5">
      <h3 class="text-lg font-bold text-[var(--color-secondary)] mb-2 group-hover:text-[var(--color-primary)] transition-colors leading-snug line-clamp-2">{title}</h3>
      <p class="text-[var(--color-text-light)] text-sm line-clamp-2 mb-4 leading-relaxed">{excerpt}</p>
      <div class="flex items-center justify-between pt-3 border-t border-[var(--color-bg-alt)]">
        <div class="flex items-center gap-3 text-xs text-[var(--color-text-light)]">
          <time datetime={date.toISOString().split('T')[0]}>{formattedDate}</time>
          <span class="flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {readTime}
          </span>
        </div>
        <span class="text-[var(--color-primary)] font-semibold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
          Read <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </span>
      </div>
    </div>
  </a>
)}
