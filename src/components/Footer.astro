---
const quickLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'DBT Therapy', href: '/services/dbt' },
  { name: 'ADHD Therapy', href: '/services/adhd' },
  { name: 'Individual', href: '/services/individual' },
  { name: 'Couples', href: '/services/couples' },
  { name: 'Group Therapy', href: '/services/group' },
  { name: 'Talks & Events', href: '/talks' },
  { name: 'Blog', href: '/blog' },
  { name: 'Prices & FAQ', href: '/prices' },
  { name: 'Book Now', href: '/book' },
  { name: 'Privacy Policy', href: '/privacy' },
];
---

<footer class="bg-[var(--color-secondary)] text-white/90" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Col 1: Brand -->
      <div>
        <img src="/images/logo.png" alt="Jared Dubbs Counselling" width="240" height="240" class="w-60 h-60 mb-4 brightness-200" />
        <p class="text-white font-semibold text-lg mb-2">Jared Dubbs Counselling</p>
        <p class="text-white/70 text-[var(--text-sm)] leading-relaxed">
          DBT and ADHD specialist counsellor in Central, Hong Kong. Helping adults, teens, and couples build the skills to feel better.
        </p>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Quick Links</h3>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2" role="list">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-white text-[var(--text-sm)] no-underline transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Contact</h3>
        <address class="not-italic space-y-3 text-[var(--text-sm)]">
          <p class="text-white/70">
            <a
              href="https://maps.google.com/?q=10/F+C+Wisdom+Centre+37+Hollywood+Road+Central+Hong+Kong"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/70 hover:text-white no-underline transition-colors"
            >
              10/F C Wisdom Centre<br />
              37 Hollywood Road<br />
              Central, Hong Kong
            </a>
          </p>
          <p>
            <a href="tel:+85257753743" class="text-white/70 hover:text-white no-underline transition-colors">
              +852 5775 3743
            </a>
          </p>
          <p>
            <a href="mailto:jared@jareddubbs.com" class="text-white/70 hover:text-white no-underline transition-colors">
              jared@jareddubbs.com
            </a>
          </p>
          <p class="text-white/50 text-xs mt-4">Hours: By appointment</p>
        </address>
      </div>
    </div>

    <!-- Crisis Line -->
    <div class="mt-12 pt-8 border-t border-white/20">
      <p class="text-center text-white/80 font-medium mb-6">
        In crisis? Call Samaritans Hong Kong:
        <a href="tel:23892222" class="text-white font-bold no-underline hover:underline">2389 2222</a>
      </p>

      <p class="text-center text-white/50 text-xs">
        &copy; {new Date().getFullYear()} Jared Dubbs Counselling LTD. All rights reserved.
      </p>
    </div>
  </div>
</footer>
