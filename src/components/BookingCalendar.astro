---

---

<div id="booking-calendar" class="space-y-6">
  <!-- Loading state -->
  <div id="cal-loading" class="text-center py-8">
    <svg class="w-8 h-8 animate-spin text-[var(--color-primary)] mx-auto mb-3" fill="none" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
    </svg>
    <p class="text-[var(--color-text-light)]">Loading available times...</p>
  </div>

  <!-- Error / fallback state -->
  <div id="cal-fallback" class="hidden bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-6 text-center">
    <p class="text-[var(--color-text-light)] mb-4">Online booking is currently unavailable. Please use the form below or contact us directly.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="tel:+85257753743" class="text-[var(--color-primary)] font-semibold no-underline hover:underline">+852 5775 3743</a>
      <a href="https://wa.me/85257753743?text=Hi%20Jared%2C%20I%27d%20like%20to%20book%20a%20discovery%20call." target="_blank" rel="noopener noreferrer" class="text-[#25D366] font-semibold no-underline hover:underline">WhatsApp</a>
    </div>
  </div>

  <!-- Calendar UI -->
  <div id="cal-picker" class="hidden">
    <!-- Step 1: Date selection -->
    <div id="cal-dates">
      <p class="font-medium text-[var(--color-text)] mb-3">Select a date:</p>
      <div id="cal-date-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2"></div>
    </div>

    <!-- Step 2: Time selection -->
    <div id="cal-times" class="hidden mt-6">
      <p class="font-medium text-[var(--color-text)] mb-1">
        Available times on <span id="cal-selected-date" class="text-[var(--color-primary)]"></span>:
      </p>
      <p class="text-[var(--color-text-light)] text-[var(--text-sm)] mb-3">All times are Hong Kong Time (HKT)</p>
      <div id="cal-time-grid" class="grid grid-cols-3 sm:grid-cols-4 gap-2"></div>
      <button type="button" id="cal-back-btn" class="mt-4 text-[var(--color-primary)] font-medium text-[var(--text-sm)] no-underline hover:underline">
        &larr; Choose a different date
      </button>
    </div>

    <!-- Step 3: Confirm details -->
    <div id="cal-confirm" class="hidden mt-6">
      <div class="bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-6 mb-6">
        <p class="text-[var(--text-sm)] text-[var(--color-text-light)] mb-1">Your discovery call:</p>
        <p id="cal-confirm-datetime" class="text-lg font-bold text-[var(--color-secondary)]"></p>
        <p class="text-[var(--text-sm)] text-[var(--color-text-light)] mt-1">15 minutes &middot; Free &middot; Phone call</p>
      </div>
      <form id="cal-form" class="space-y-4" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="cal-name" class="block text-[var(--text-sm)] font-medium text-[var(--color-text)] mb-1.5">
              Full Name <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
            </label>
            <input type="text" id="cal-name" name="name" required autocomplete="name"
              class="w-full px-4 py-3 border border-[var(--color-bg-alt)] rounded-[var(--radius)] text-[var(--color-text)] bg-white focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/20 outline-none transition-colors min-h-[44px]"
              placeholder="Your name" />
          </div>
          <div>
            <label for="cal-email" class="block text-[var(--text-sm)] font-medium text-[var(--color-text)] mb-1.5">
              Email <span class="text-[var(--color-error)]" aria-hidden="true">*</span>
            </label>
            <input type="email" id="cal-email" name="email" required autocomplete="email"
              class="w-full px-4 py-3 border border-[var(--color-bg-alt)] rounded-[var(--radius)] text-[var(--color-text)] bg-white focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/20 outline-none transition-colors min-h-[44px]"
              placeholder="you@example.com" />
          </div>
        </div>
        <div>
          <label for="cal-phone" class="block text-[var(--text-sm)] font-medium text-[var(--color-text)] mb-1.5">
            Phone Number <span class="text-[var(--color-text-light)]">(for the call)</span>
          </label>
          <input type="tel" id="cal-phone" name="phone" autocomplete="tel"
            class="w-full px-4 py-3 border border-[var(--color-bg-alt)] rounded-[var(--radius)] text-[var(--color-text)] bg-white focus:border-[var(--color-primary)] focus:ring-2 focus:ring-[var(--color-primary)]/20 outline-none transition-colors min-h-[44px]"
            placeholder="+852 XXXX XXXX" />
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <button type="submit" id="cal-submit"
            class="px-8 py-4 bg-[var(--color-primary)] text-white font-semibold rounded-[var(--radius)] hover:bg-[var(--color-primary-hover)] transition-colors min-h-[44px] flex items-center justify-center gap-2">
            <span id="cal-submit-text">Confirm Booking</span>
            <svg id="cal-submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          </button>
          <button type="button" id="cal-change-time" class="px-6 py-3 text-[var(--color-primary)] font-medium min-h-[44px]">
            Change time
          </button>
        </div>
        <p id="cal-form-error" class="hidden text-[var(--color-accent)] text-[var(--text-sm)]" role="alert"></p>
      </form>
    </div>

    <!-- Step 4: Success -->
    <div id="cal-success" class="hidden bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-8 text-center">
      <svg class="w-16 h-16 text-[var(--color-primary)] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-2xl font-bold text-[var(--color-secondary)] mb-3">You're booked!</h3>
      <p id="cal-success-details" class="text-[var(--color-text-light)] text-lg leading-relaxed max-w-lg mx-auto mb-2"></p>
      <p class="text-[var(--color-text-light)] text-[var(--text-sm)]">You'll receive a confirmation email shortly. If you need to reschedule, just reply to that email or call us.</p>
    </div>
  </div>
</div>

<script>
  const state = {
    slots: {},
    selectedDate: null,
    selectedTime: null,
    appointmentTypeId: null,
    practitionerId: null,
  };

  const $ = (id: string) => document.getElementById(id);

  async function init() {
    try {
      const res = await fetch('/api/cliniko/available-times');
      const data = await res.json();

      if (!data.slots || Object.keys(data.slots).length === 0) {
        $('cal-loading')!.classList.add('hidden');
        $('cal-fallback')!.classList.remove('hidden');
        return;
      }

      state.slots = data.slots;
      state.appointmentTypeId = data.appointmentTypeId;
      state.practitionerId = data.practitionerId;

      renderDates();
      $('cal-loading')!.classList.add('hidden');
      $('cal-picker')!.classList.remove('hidden');
    } catch {
      $('cal-loading')!.classList.add('hidden');
      $('cal-fallback')!.classList.remove('hidden');
    }
  }

  function renderDates() {
    const grid = $('cal-date-grid')!;
    grid.innerHTML = '';
    const dates = Object.keys(state.slots).sort();

    for (const date of dates) {
      const d = new Date(date + 'T00:00:00');
      const dayName = d.toLocaleDateString('en-GB', { weekday: 'short' });
      const dayNum = d.getDate();
      const month = d.toLocaleDateString('en-GB', { month: 'short' });
      const slotCount = state.slots[date].length;
      const availability =
        slotCount >= 10 ? { label: 'High', color: '#16a34a' } :
        slotCount >= 4  ? { label: 'Medium', color: 'var(--color-primary)' } :
                          { label: 'Low', color: '#d97706' };

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'p-3 rounded-[var(--radius)] border border-[var(--color-bg-alt)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 transition-all text-center min-h-[44px]';
      btn.innerHTML = `
        <span class="block text-xs text-[var(--color-text-light)]">${dayName}</span>
        <span class="block text-lg font-bold text-[var(--color-secondary)]">${dayNum}</span>
        <span class="block text-xs text-[var(--color-text-light)]">${month}</span>
        <span class="block text-xs mt-1" style="color: ${availability.color}">${availability.label}</span>
      `;
      btn.addEventListener('click', () => selectDate(date));
      grid.appendChild(btn);
    }
  }

  function selectDate(date: string) {
    state.selectedDate = date;
    const d = new Date(date + 'T00:00:00');
    const display = d.toLocaleDateString('en-GB', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
    });
    $('cal-selected-date')!.textContent = display;

    const grid = $('cal-time-grid')!;
    grid.innerHTML = '';
    const slots = state.slots[date] || [];

    for (const slot of slots) {
      const time = new Date(slot.start);
      const display = time.toLocaleTimeString('en-GB', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: true,
        timeZone: 'Asia/Hong_Kong',
      });

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className =
        'px-4 py-3 rounded-[var(--radius)] border border-[var(--color-bg-alt)] hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white transition-all font-medium min-h-[44px]';
      btn.textContent = display;
      btn.addEventListener('click', () => selectTime(slot.start, display));
      grid.appendChild(btn);
    }

    $('cal-dates')!.classList.add('hidden');
    $('cal-times')!.classList.remove('hidden');
  }

  function selectTime(isoStart: string, displayTime: string) {
    state.selectedTime = isoStart;
    const d = new Date(state.selectedDate + 'T00:00:00');
    const dateDisplay = d.toLocaleDateString('en-GB', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    });
    $('cal-confirm-datetime')!.textContent = `${dateDisplay} at ${displayTime} (HKT)`;

    $('cal-times')!.classList.add('hidden');
    $('cal-confirm')!.classList.remove('hidden');
  }

  // Navigation
  $('cal-back-btn')?.addEventListener('click', () => {
    $('cal-times')!.classList.add('hidden');
    $('cal-dates')!.classList.remove('hidden');
  });

  $('cal-change-time')?.addEventListener('click', () => {
    $('cal-confirm')!.classList.add('hidden');
    $('cal-times')!.classList.remove('hidden');
  });

  // Form submission
  $('cal-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errorEl = $('cal-form-error')!;
    errorEl.classList.add('hidden');

    const name = ($('cal-name') as HTMLInputElement).value.trim();
    const email = ($('cal-email') as HTMLInputElement).value.trim();
    const phone = ($('cal-phone') as HTMLInputElement).value.trim();

    if (!name) {
      errorEl.textContent = 'Please enter your name';
      errorEl.classList.remove('hidden');
      return;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Please enter a valid email';
      errorEl.classList.remove('hidden');
      return;
    }

    const submitBtn = $('cal-submit') as HTMLButtonElement;
    submitBtn.disabled = true;
    $('cal-submit-text')!.textContent = 'Booking...';
    $('cal-submit-spinner')!.classList.remove('hidden');

    try {
      const res = await fetch('/api/cliniko/book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          email,
          phone: phone || undefined,
          appointmentStart: state.selectedTime,
          appointmentTypeId: state.appointmentTypeId,
          practitionerId: state.practitionerId,
        }),
      });

      const data = await res.json();

      if (data.success) {
        $('cal-confirm')!.classList.add('hidden');
        $('cal-success-details')!.textContent = data.message;
        $('cal-success')!.classList.remove('hidden');
      } else if (res.status === 409) {
        errorEl.textContent = data.error || 'This slot is no longer available. Please choose another time.';
        errorEl.classList.remove('hidden');
        // Go back to time selection
        setTimeout(() => {
          $('cal-confirm')!.classList.add('hidden');
          selectDate(state.selectedDate!);
        }, 2000);
      } else {
        errorEl.textContent = data.error || 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Connection error. Please try again or call +852 5775 3743.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      $('cal-submit-text')!.textContent = 'Confirm Booking';
      $('cal-submit-spinner')!.classList.add('hidden');
    }
  });

  init();
</script>
