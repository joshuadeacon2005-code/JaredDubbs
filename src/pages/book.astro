---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingCalendar from '../components/BookingCalendar.astro';
import ContactForm from '../components/ContactForm.astro';
import HowItWorks from '../components/HowItWorks.astro';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Book a Consultation — Jared Dubbs Counselling',
  url: 'https://jareddubbs.com/book',
  description: 'Book a free discovery call with Jared Dubbs for counselling in Central Hong Kong.',
});
---

<BaseLayout
  title="Book a Consultation — Jared Dubbs Counselling, Hong Kong"
  description="Book a free 15-minute discovery call with Jared Dubbs. Counselling for ADHD, autism, LGBTQ+, and more in Central Hong Kong. No referral needed."
  schema={schema}
>
  <!-- Book a Discovery Call -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="mb-4">Book a Free Discovery Call</h1>
      <p class="text-[var(--color-text-light)] text-lg leading-relaxed mb-2">
        A 15-minute phone call to talk about what you're going through and whether we're a good fit. No commitment, no pressure.
      </p>
      <p class="text-[var(--color-text-light)] leading-relaxed mb-10">
        Choose a time that works for you, or use the form below if you'd prefer us to get in touch.
      </p>

      <BookingCalendar />
    </div>
  </section>

  <!-- Or Send a Message -->
  <section class="py-16 md:py-20 bg-[var(--color-bg-alt)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4">Or Send a Message</h2>
      <p class="text-[var(--color-text-light)] leading-relaxed mb-10">
        Not ready to book? No problem. Fill in this form and I'll get back to you within 24 hours. Your information is kept strictly confidential.
      </p>

      <ContactForm />
    </div>
  </section>

  <HowItWorks />

  <!-- Alternative Contact -->
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8">Prefer to reach out directly?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a href="tel:+85257753743" class="block bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-6 text-center no-underline hover:shadow-md transition-shadow">
          <svg class="w-8 h-8 text-[var(--color-primary)] mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <p class="font-semibold text-[var(--color-secondary)]">Call</p>
          <p class="text-[var(--color-primary)] mt-1">+852 5775 3743</p>
        </a>
        <a href="mailto:hello@jareddubbs.com" class="block bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-6 text-center no-underline hover:shadow-md transition-shadow">
          <svg class="w-8 h-8 text-[var(--color-primary)] mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <p class="font-semibold text-[var(--color-secondary)]">Email</p>
          <p class="text-[var(--color-primary)] mt-1">hello@jareddubbs.com</p>
        </a>
        <a href="https://maps.google.com/?q=10/F+C+Wisdom+Centre+37+Hollywood+Road+Central+Hong+Kong" target="_blank" rel="noopener noreferrer" class="block bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-6 text-center no-underline hover:shadow-md transition-shadow">
          <svg class="w-8 h-8 text-[var(--color-primary)] mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="font-semibold text-[var(--color-secondary)]">Visit</p>
          <p class="text-[var(--color-text-light)] text-[var(--text-sm)] mt-1">10/F C Wisdom Centre, 37 Hollywood Rd, Central</p>
        </a>
      </div>

      <!-- Google Map -->
      <div class="mt-10 rounded-[var(--radius-lg)] overflow-hidden">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3691.9!2d114.15!3d22.28!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s37+Hollywood+Road+Central+Hong+Kong!5e0!3m2!1sen!2shk!4v1"
          width="100%"
          height="350"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Jared Dubbs Counselling office location — 37 Hollywood Road, Central, Hong Kong"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
