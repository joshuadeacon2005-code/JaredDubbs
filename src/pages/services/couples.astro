---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  name: 'Couples & Family Therapy Hong Kong',
  url: 'https://jareddubbs.com/services/couples',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jareddubbs.com' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://jareddubbs.com/services' },
      { '@type': 'ListItem', position: 3, name: 'Couples & Parent-Teen' },
    ],
  },
});
---

<BaseLayout
  title="Couples & Family Therapy Hong Kong | Jared Dubbs Counselling"
  description="Couples and parent-teen therapy in Central Hong Kong. Rebuild communication, navigate conflict, and strengthen your relationships in a safe, structured space."
  schema={schema}
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-[var(--text-sm)]" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2" role="list">
      <li><a href="/" class="text-[var(--color-text-light)] hover:text-[var(--color-primary)] no-underline">Home</a></li>
      <li class="text-[var(--color-text-light)]">/</li>
      <li><a href="/services/couples" class="text-[var(--color-text-light)] hover:text-[var(--color-primary)] no-underline">Services</a></li>
      <li class="text-[var(--color-text-light)]">/</li>
      <li class="text-[var(--color-primary)] font-medium" aria-current="page">Couples & Parent-Teen</li>
    </ol>
  </nav>

  <Hero
    title="Relationships take work — having the right support makes all the difference"
    subtitle="Whether you're a couple navigating conflict or a parent struggling to connect with your teen, therapy provides a safe space to rebuild communication and understanding."
    ctaText="Book a Free Discovery Call"
    ctaLink="/book"
    compact={true}
  />

  <!-- Who This Is For -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8">Who This Is For</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-8">
          <h3 class="text-xl font-bold mb-4">Couples</h3>
          <ul class="space-y-3 text-[var(--color-text-light)]">
            <li>Communication has broken down or become hostile</li>
            <li>You feel disconnected or misunderstood</li>
            <li>Conflict keeps repeating the same patterns</li>
            <li>Trust has been damaged</li>
            <li>Navigating a major life transition together</li>
            <li>One or both partners are neurodivergent</li>
          </ul>
        </div>
        <div class="bg-[var(--color-bg-alt)] rounded-[var(--radius-lg)] p-8">
          <h3 class="text-xl font-bold mb-4">Parent and Teen</h3>
          <ul class="space-y-3 text-[var(--color-text-light)]">
            <li>Your teen is withdrawn, anxious, or acting out</li>
            <li>Communication feels impossible</li>
            <li>Navigating an ADHD or neurodivergence diagnosis</li>
            <li>School or behaviour challenges</li>
            <li>You want to support your teen but don't know how</li>
            <li>Blended family dynamics</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="py-16 md:py-20 bg-[var(--color-bg-alt)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8">How We Work</h2>
      <p class="text-[var(--color-text-light)] leading-relaxed mb-6">
        Couples and parent-teen sessions are 75 minutes, giving enough time for both parties to be heard and for meaningful work to happen. Sessions are structured but flexible — I'm not there to take sides, but to help you both communicate more effectively.
      </p>
      <p class="text-[var(--color-text-light)] leading-relaxed mb-6">
        I draw from DBT interpersonal effectiveness skills, helping you learn to express needs, set boundaries, and navigate disagreements without damaging the relationship. For parent-teen work, I also incorporate SPACE (Supporting Parents of Anxious Childhood Emotions), a Yale-developed programme that empowers parents to support their child's mental health.
      </p>
      <div class="bg-white rounded-[var(--radius-lg)] p-6 mt-8">
        <h3 class="text-lg font-bold mb-2">Session Details</h3>
        <p class="text-3xl font-bold text-[var(--color-primary)] mb-2">75 minutes</p>
        <p class="text-[var(--color-text-light)]">HKD $3,000 — in person or online via Zoom</p>
        <p class="text-[var(--color-text-light)] text-[var(--text-sm)] mt-2">
          <a href="/prices" class="text-[var(--color-primary)] no-underline hover:underline">View all pricing &rarr;</a>
        </p>
      </div>
    </div>
  </section>

  <FinalCTA
    heading="Ready to start rebuilding?"
    subtext="Book a free discovery call and let's talk about how we can work together."
  />
</BaseLayout>
