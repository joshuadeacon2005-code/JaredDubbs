---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const services = [
  {
    title: 'ADHD & Neurodivergence',
    description: 'From a therapist who lives it too. Executive functioning, emotional regulation, and building a life that fits your brain.',
    tags: ['Executive Function', 'Unmasking', 'Self-Compassion'],
    link: '/services/adhd',
    color: 'var(--color-primary)',
  },
  {
    title: 'ASD & Autism',
    description: 'Your user guide — not a fix. Support for teens, adults, and careers, built around how autistic brains actually work.',
    tags: ['Teens', 'Adults', 'Careers', 'Late Diagnosis'],
    link: '/services/asd',
    color: 'var(--color-accent)',
  },
  {
    title: 'LGBTQ+ Counselling',
    description: 'Affirming therapy for individuals and couples. Identity, relationships, and community — without having to explain who you are first.',
    tags: ['Individual', 'Couples', 'Identity', 'Affirming'],
    link: '/services/lgbtq',
    color: 'var(--color-gold)',
  },
  {
    title: 'Individual Counselling',
    description: 'One-on-one therapy tailored to you — anxiety, depression, burnout, identity, sleep, and life transitions.',
    tags: ['Anxiety', 'Depression', 'Burnout', 'Life Transitions'],
    link: '/services/individual',
    color: 'var(--color-primary)',
  },
  {
    title: 'Couples & Parent-Teen',
    description: 'Rebuild communication and navigate conflict in 75-minute sessions designed for two.',
    tags: ['Communication', 'Conflict', 'SPACE (Yale)'],
    link: '/services/couples',
    color: 'var(--color-accent)',
  },
  {
    title: 'DBT Therapy',
    description: 'Evidence-based skills for managing intense emotions, tolerating distress, and building stronger relationships.',
    tags: ['Emotional Regulation', 'BPD', 'Distress Tolerance'],
    link: '/services/dbt',
    color: 'var(--color-gold)',
  },
  {
    title: 'Group Therapy',
    description: 'DBT skills groups, ADHD support, PEERS social skills, and LGBTQ+ community in small therapist-led groups.',
    tags: ['DBT Skills', 'ADHD Support', 'PEERS'],
    link: '/services/group',
    color: 'var(--color-primary)',
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  name: 'Counselling Services — Jared Dubbs',
  url: 'https://jareddubbs.com/services',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://jareddubbs.com' },
      { '@type': 'ListItem', position: 2, name: 'Services' },
    ],
  },
});
---

<BaseLayout
  title="Counselling Services | Jared Dubbs — Central, Hong Kong"
  description="ADHD, autism, LGBTQ+ affirming therapy, individual counselling, couples therapy, and group programmes in Central Hong Kong. Find the right fit for you."
  schema={schema}
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-[var(--text-sm)]" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2" role="list">
      <li><a href="/" class="text-[var(--color-text-light)] hover:text-[var(--color-primary)] no-underline">Home</a></li>
      <li class="text-[var(--color-text-light)]">/</li>
      <li class="text-[var(--color-primary)] font-medium" aria-current="page">Services</li>
    </ol>
  </nav>

  <section class="pt-8 pb-4">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="w-12 h-1 bg-[var(--color-gold)] rounded-full mb-4"></div>
      <h1 class="text-3xl md:text-4xl leading-[1.15] mb-3">How I Can Help</h1>
      <p class="text-[var(--color-text-light)] text-base mb-0">Not sure where you fit? <a href="/book" class="font-semibold no-underline hover:underline">Book a free call</a> and we'll figure it out.</p>
    </div>
  </section>

  <section class="py-6 md:py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-3 reveal-stagger">
        {services.map((service) => (
          <a
            href={service.link}
            class="reveal-item group flex items-center justify-between bg-white rounded-[var(--radius)] px-6 py-5 shadow-sm hover:shadow-md transition-all duration-200 no-underline border-l-4"
            style={`border-color: ${service.color}`}
          >
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-4 mb-1">
                <h2 class="text-lg font-bold text-[var(--color-secondary)] group-hover:text-[var(--color-primary)] transition-colors shrink-0">{service.title}</h2>
                <div class="hidden md:flex flex-wrap gap-1.5">
                  {service.tags.map((tag) => (
                    <span class="inline-block px-2 py-0.5 bg-[var(--color-bg-alt)] text-[var(--color-text-light)] text-xs rounded-[var(--radius-full)]">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <p class="text-[var(--color-text-light)] text-[var(--text-sm)] leading-relaxed">{service.description}</p>
            </div>
            <span class="text-[var(--color-primary)] font-semibold text-[var(--text-sm)] group-hover:translate-x-1 transition-transform shrink-0 ml-6 hidden sm:inline-flex">
              &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing callout -->
  <section class="py-6 bg-[var(--color-bg-alt)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <p class="text-[var(--color-text-light)] text-lg">
        Looking for pricing? <a href="/prices" class="text-[var(--color-primary)] font-semibold no-underline hover:underline">View all session rates and packages &rarr;</a>
      </p>
    </div>
  </section>

  <FinalCTA
    heading="Not sure which service is right for you?"
    subtext="Book a free 15-minute discovery call. We'll talk through what you're dealing with and figure out the best path forward — no commitment."
  />
</BaseLayout>
