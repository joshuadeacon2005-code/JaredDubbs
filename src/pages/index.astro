---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AboutPreview from '../components/AboutPreview.astro';
import EmpathyBridge from '../components/EmpathyBridge.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import WhyChooseMe from '../components/WhyChooseMe.astro';
import Testimonials from '../components/Testimonials.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BlogPreview from '../components/BlogPreview.astro';
import HomeFAQ from '../components/HomeFAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { siteCopy } from '../lib/site-copy';

const heroHeadline = await siteCopy(
  'homepage_hero_headline',
  "You don't have to figure it out alone."
);
const heroSubheadline = await siteCopy(
  'homepage_hero_subheadline',
  "I'm Jared — a counsellor in Central Hong Kong. I help adults, teens, and couples navigate ADHD, autism, emotional regulation, and life's toughest moments — not just cope, but genuinely feel better."
);
const philosophyQuote = await siteCopy(
  'homepage_philosophy_quote',
  "I don't believe in one-size-fits-all therapy. I believe in meeting you exactly where you are — and building from there."
);

const testimonials = [
  {
    quote: "Thank you for starting me out on this journey and supporting me. You have made a profound difference in my life.",
  },
  {
    quote: "You have made a huge difference in my son's life. I want to sing your praises. The teachers have also noticed how much he has improved thanks to his time with you.",
  },
  {
    quote: "I never thought there would be a day where I didn't have panic attacks. You helped me to get to know myself more. I have grown mentally and I got to experience real happiness in life.",
  },
  {
    quote: "For the first time in my life I feel like someone actually understands how my brain works. Jared doesn't just talk about ADHD — he lives it, and that makes all the difference.",
  },
  {
    quote: "I was sceptical about group therapy, but the DBT skills group changed everything. Learning alongside other people going through the same thing made me feel so much less alone.",
  },
  {
    quote: "My teenager and I were barely speaking. After a few sessions with Jared, we're actually communicating again. He has a way of making both sides feel heard.",
  },
  {
    quote: "I came in for anxiety and ended up discovering so much more about myself. Jared creates this space where you feel safe enough to be honest — even about the hard stuff.",
  },
  {
    quote: "As an expat in Hong Kong, finding a therapist who gets the unique pressures we face was everything. Jared understood immediately without me having to over-explain.",
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://jareddubbs.com/#business',
      name: 'Jared Dubbs Counselling',
      description: 'Counsellor specialising in ADHD, autism, and LGBTQ+ affirming therapy in Central, Hong Kong.',
      url: 'https://jareddubbs.com',
      telephone: '+852 5775 3743',
      email: 'hello@jareddubbs.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '10/F C Wisdom Centre, 37 Hollywood Road',
        addressLocality: 'Central',
        addressRegion: 'Hong Kong',
        addressCountry: 'HK',
      },
      priceRange: 'HKD 2000-3000',
    },
    {
      '@type': 'Person',
      '@id': 'https://jareddubbs.com/#person',
      name: 'Jared Dubbs',
      jobTitle: 'Counsellor',
      worksFor: { '@id': 'https://jareddubbs.com/#business' },
      alumniOf: [
        { '@type': 'CollegeOrUniversity', name: 'Monash University' },
        { '@type': 'CollegeOrUniversity', name: 'University of Hong Kong' },
        { '@type': 'CollegeOrUniversity', name: 'Austin College' },
      ],
    },
  ],
});
---

<BaseLayout
  title="Jared Dubbs Counselling — ADHD, Autism & LGBTQ+ Therapy in Central, Hong Kong"
  description="Counsellor in Central Hong Kong specialising in ADHD, autism, LGBTQ+ affirming therapy, and emotional regulation for adults, teens, and couples. Book a free consultation."
  schema={schema}
>
  <!-- 1. Full-bleed cinematic hero -->
  <Hero
    title={heroHeadline}
    subtitle={heroSubheadline}
    ctaText="Book a Free Discovery Call"
    ctaLink="/book"
    secondaryCta="How I Can Help"
    secondaryCtaLink="#services"
    bgImage="/images/jared-hero.png"
    showTrustBar={true}
    trustItems={[
      { label: "Master's in Counselling (Monash)", href: '/about' },
      { label: 'ADHD Lived Experience', href: '/services/adhd' },
      { label: 'Autism & ASD Support', href: '/services/asd' },
      { label: 'LGBTQ+ Affirming', href: '/services/lgbtq' },
      { label: 'SPACE Trained (Yale)', href: '/services/asd' },
    ]}
  />

  <!-- 2. Meet Jared early — personal connection first -->
  <AboutPreview />

  <!-- 3. Empathy bridge — "sound familiar?" -->
  <div id="empathy">
    <EmpathyBridge />
  </div>

  <!-- 3.5. What can we work on together — demographic pain points -->
  <section class="py-16 md:py-20 bg-[var(--color-bg-alt)]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <h2>What Can We Work on Together?</h2>
        <p class="text-[var(--color-text-light)] mt-4">People come to therapy for all kinds of reasons. Here are some of the most common.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal-stagger">
        <div class="reveal-item bg-white rounded-[var(--radius-lg)] p-6 border-t-4 border-[var(--color-primary)]">
          <h3 class="text-lg font-bold mb-4">Men</h3>
          <ul class="space-y-2 text-[var(--color-text-light)] text-[var(--text-sm)]">
            <li class="flex items-start gap-2"><span class="text-[var(--color-primary)] mt-1 shrink-0">&#9679;</span>Anxiety and stress</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-primary)] mt-1 shrink-0">&#9679;</span>Depression and mood issues</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-primary)] mt-1 shrink-0">&#9679;</span>Self-esteem and identity</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-primary)] mt-1 shrink-0">&#9679;</span>Relationship and family problems</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-primary)] mt-1 shrink-0">&#9679;</span>Burnout and work pressure</li>
          </ul>
        </div>
        <div class="reveal-item bg-white rounded-[var(--radius-lg)] p-6 border-t-4 border-[var(--color-gold)]">
          <h3 class="text-lg font-bold mb-4">Women</h3>
          <ul class="space-y-2 text-[var(--color-text-light)] text-[var(--text-sm)]">
            <li class="flex items-start gap-2"><span class="text-[var(--color-gold)] mt-1 shrink-0">&#9679;</span>Anxiety and chronic stress</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-gold)] mt-1 shrink-0">&#9679;</span>Depression and low mood</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-gold)] mt-1 shrink-0">&#9679;</span>Relationship and family problems</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-gold)] mt-1 shrink-0">&#9679;</span>Self-esteem and identity struggles</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-gold)] mt-1 shrink-0">&#9679;</span>Trauma, grief, and life transitions</li>
          </ul>
        </div>
        <div class="reveal-item bg-white rounded-[var(--radius-lg)] p-6 border-t-4 border-[var(--color-accent)]">
          <h3 class="text-lg font-bold mb-4">Couples</h3>
          <ul class="space-y-2 text-[var(--color-text-light)] text-[var(--text-sm)]">
            <li class="flex items-start gap-2"><span class="text-[var(--color-accent)] mt-1 shrink-0">&#9679;</span>Communication breakdowns</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-accent)] mt-1 shrink-0">&#9679;</span>Frequent conflicts and arguments</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-accent)] mt-1 shrink-0">&#9679;</span>Trust issues and betrayal</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-accent)] mt-1 shrink-0">&#9679;</span>Intimacy and connection</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-accent)] mt-1 shrink-0">&#9679;</span>Parenting differences</li>
          </ul>
        </div>
        <div class="reveal-item bg-white rounded-[var(--radius-lg)] p-6 border-t-4 border-[var(--color-secondary)]">
          <h3 class="text-lg font-bold mb-4">Teens</h3>
          <ul class="space-y-2 text-[var(--color-text-light)] text-[var(--text-sm)]">
            <li class="flex items-start gap-2"><span class="text-[var(--color-secondary)] mt-1 shrink-0">&#9679;</span>Anxiety and school stress</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-secondary)] mt-1 shrink-0">&#9679;</span>Depression and mood issues</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-secondary)] mt-1 shrink-0">&#9679;</span>Self-esteem and body image</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-secondary)] mt-1 shrink-0">&#9679;</span>Family conflict</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-secondary)] mt-1 shrink-0">&#9679;</span>Grief, loss, and social challenges</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Philosophy / approach statement -->
  <section class="bg-[var(--color-secondary)] py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <div class="w-12 h-1 bg-[var(--color-accent-light)] rounded-full mx-auto mb-8"></div>
      <blockquote class="text-white text-2xl md:text-3xl font-light leading-relaxed italic" style="font-family: var(--font-serif)">
        "{philosophyQuote}"
      </blockquote>
      <p class="text-[var(--color-accent-light)] mt-8 font-medium tracking-wide text-[var(--text-sm)] uppercase">— Jared Dubbs</p>
    </div>
  </section>

  <!-- 5. Services -->
  <div id="services">
    <ServicesGrid />
  </div>

  <!-- 6. Testimonials -->
  <Testimonials items={testimonials} />

  <!-- 7. Why Choose Me -->
  <WhyChooseMe />

  <!-- 8. How It Works -->
  <HowItWorks />

  <!-- 9. FAQ with topic pills -->
  <HomeFAQ />

  <!-- 10. Blog -->
  <BlogPreview />

  <!-- 11. Final CTA -->
  <FinalCTA />
</BaseLayout>
