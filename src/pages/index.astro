---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AboutPreview from '../components/AboutPreview.astro';
import EmpathyBridge from '../components/EmpathyBridge.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import WhyChooseMe from '../components/WhyChooseMe.astro';
import Testimonials from '../components/Testimonials.astro';
import HowItWorks from '../components/HowItWorks.astro';
import BlogPreview from '../components/BlogPreview.astro';
import HomeFAQ from '../components/HomeFAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';

const testimonials = [
  {
    quote: "Thank you for starting me out on this journey and supporting me. You have made a profound difference in my life.",
  },
  {
    quote: "You have made a huge difference in my son's life. I want to sing your praises. The teachers have also noticed how much he has improved thanks to his time with you.",
  },
  {
    quote: "I never thought there would be a day where I didn't have panic attacks. You helped me to get to know myself more. I have grown mentally and I got to experience real happiness in life.",
  },
  {
    quote: "For the first time in my life I feel like someone actually understands how my brain works. Jared doesn't just talk about ADHD — he lives it, and that makes all the difference.",
  },
  {
    quote: "I was sceptical about group therapy, but the DBT skills group changed everything. Learning alongside other people going through the same thing made me feel so much less alone.",
  },
  {
    quote: "My teenager and I were barely speaking. After a few sessions with Jared, we're actually communicating again. He has a way of making both sides feel heard.",
  },
  {
    quote: "I came in for anxiety and ended up discovering so much more about myself. Jared creates this space where you feel safe enough to be honest — even about the hard stuff.",
  },
  {
    quote: "As an expat in Hong Kong, finding a therapist who gets the unique pressures we face was everything. Jared understood immediately without me having to over-explain.",
  },
];

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'LocalBusiness',
      '@id': 'https://jareddubbs.com/#business',
      name: 'Jared Dubbs Counselling',
      description: 'DBT and ADHD specialist counsellor in Central, Hong Kong.',
      url: 'https://jareddubbs.com',
      telephone: '+852 5775 3743',
      email: 'jared@jareddubbs.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '10/F C Wisdom Centre, 37 Hollywood Road',
        addressLocality: 'Central',
        addressRegion: 'Hong Kong',
        addressCountry: 'HK',
      },
      priceRange: 'HKD 2000-3000',
    },
    {
      '@type': 'Person',
      '@id': 'https://jareddubbs.com/#person',
      name: 'Jared Dubbs',
      jobTitle: 'Counsellor',
      worksFor: { '@id': 'https://jareddubbs.com/#business' },
      alumniOf: [
        { '@type': 'CollegeOrUniversity', name: 'Monash University' },
        { '@type': 'CollegeOrUniversity', name: 'University of Hong Kong' },
        { '@type': 'CollegeOrUniversity', name: 'Austin College' },
      ],
    },
  ],
});
---

<BaseLayout
  title="Jared Dubbs Counselling — DBT & ADHD Therapy in Central, Hong Kong"
  description="Specialising in DBT and ADHD therapy for adults, teens, and couples in Central HK. Book a free consultation with a therapist who truly understands."
  schema={schema}
>
  <!-- 1. Full-bleed cinematic hero -->
  <Hero
    title="You don't have to figure<br class='hidden md:block' /> it out alone."
    subtitle="I'm Jared — a counsellor in Central Hong Kong specialising in DBT and ADHD. I help adults, teens, and couples build the skills to feel better, not just cope."
    ctaText="Book a Free Discovery Call"
    ctaLink="/book"
    secondaryCta="How I Can Help"
    secondaryCtaLink="#services"
    bgImage="/images/jared-hero.png"
    showTrustBar={true}
    trustItems={[
      "Master's in Counselling (Monash)",
      'DBT Specialist',
      'ADHD Lived Experience',
      'LGBTQ+ Affirming',
      'SPACE Trained (Yale)',
    ]}
  />

  <!-- 2. Meet Jared early — personal connection first -->
  <AboutPreview />

  <!-- 3. Empathy bridge — "sound familiar?" -->
  <div id="empathy">
    <EmpathyBridge />
  </div>

  <!-- 4. Philosophy / approach statement -->
  <section class="bg-[var(--color-secondary)] py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <div class="w-12 h-1 bg-[var(--color-accent-light)] rounded-full mx-auto mb-8"></div>
      <blockquote class="text-white text-2xl md:text-3xl font-light leading-relaxed italic" style="font-family: var(--font-serif)">
        "I don't believe in one-size-fits-all therapy. I believe in meeting you exactly where you are — and building from there."
      </blockquote>
      <p class="text-[var(--color-accent-light)] mt-8 font-medium tracking-wide text-[var(--text-sm)] uppercase">— Jared Dubbs</p>
    </div>
  </section>

  <!-- 5. Services -->
  <div id="services">
    <ServicesGrid />
  </div>

  <!-- 6. Testimonials -->
  <Testimonials items={testimonials} />

  <!-- 7. Why Choose Me -->
  <WhyChooseMe />

  <!-- 8. How It Works -->
  <HowItWorks />

  <!-- 9. FAQ with topic pills -->
  <HomeFAQ />

  <!-- 10. Blog -->
  <BlogPreview />

  <!-- 11. Final CTA -->
  <FinalCTA />
</BaseLayout>
