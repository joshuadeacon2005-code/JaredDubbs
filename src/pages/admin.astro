---
// Admin page — no BaseLayout (no nav/footer, noindex)
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin | Jared Dubbs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'DM Sans', sans-serif; background: #f8f7f4; color: #2c2c2c; min-height: 100vh; }

      /* Login */
      .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; }
      .login-box { background: white; border-radius: 12px; padding: 2.5rem; max-width: 380px; width: 100%; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
      .login-box h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
      .login-box p { color: #666; font-size: 0.875rem; margin-bottom: 1.5rem; }

      /* Form elements */
      label { display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.375rem; color: #444; }
      input, textarea, select { width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #ddd; border-radius: 8px; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s; }
      input:focus, textarea:focus, select:focus { outline: none; border-color: #3d6b5e; box-shadow: 0 0 0 3px rgba(61,107,94,0.1); }
      textarea { resize: vertical; min-height: 300px; font-family: 'Courier New', monospace; font-size: 0.875rem; line-height: 1.6; }

      .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.625rem 1.25rem; border: none; border-radius: 8px; font-family: inherit; font-size: 0.9375rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
      .btn-primary { background: #3d6b5e; color: white; }
      .btn-primary:hover { background: #2f5349; }
      .btn-primary:disabled { background: #aaa; cursor: not-allowed; }
      .btn-secondary { background: #e8e6e1; color: #444; }
      .btn-secondary:hover { background: #ddd; }

      /* Dashboard */
      .dashboard { display: none; }
      .dashboard.active { display: block; }
      .topbar { background: white; border-bottom: 1px solid #e8e6e1; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; }
      .topbar h1 { font-size: 1.125rem; }
      .container { max-width: 800px; margin: 0 auto; padding: 2rem; }

      /* Post list */
      .post-list { list-style: none; }
      .post-item { background: white; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: space-between; border: 1px solid #e8e6e1; }
      .post-item .title { font-weight: 600; }
      .post-item .meta { font-size: 0.8125rem; color: #888; margin-top: 0.25rem; }
      .badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
      .badge-adhd { background: #fef3c7; color: #92400e; }
      .badge-dbt { background: #d1fae5; color: #065f46; }
      .badge-anxiety { background: #fef9c3; color: #713f12; }
      .badge-therapy { background: #f3e8ff; color: #6b21a8; }
      .badge-lgbtq { background: #fce7f3; color: #9d174d; }
      .badge-asd { background: #e0f2fe; color: #075985; }

      /* Editor */
      .editor { display: none; }
      .editor.active { display: block; }
      .field { margin-bottom: 1.25rem; }
      .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .help { font-size: 0.75rem; color: #888; margin-top: 0.25rem; }

      /* Messages */
      .msg { padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem; font-size: 0.875rem; display: none; }
      .msg.error { display: block; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
      .msg.success { display: block; background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }

      /* Preview */
      .preview-pane { background: white; border: 1px solid #e8e6e1; border-radius: 8px; padding: 1.5rem; margin-top: 1rem; display: none; }
      .preview-pane.active { display: block; }
      .preview-pane h2, .preview-pane h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
      .preview-pane p { margin-bottom: 0.75rem; line-height: 1.7; color: #555; }
      .preview-pane ul, .preview-pane ol { margin: 0.5rem 0 0.75rem 1.5rem; color: #555; }

      .tab-bar { display: flex; gap: 0; margin-bottom: -1px; position: relative; z-index: 1; }
      .tab { padding: 0.5rem 1rem; border: 1px solid transparent; border-radius: 8px 8px 0 0; cursor: pointer; font-weight: 500; font-size: 0.875rem; color: #888; background: transparent; }
      .tab.active { background: white; border-color: #e8e6e1; border-bottom-color: white; color: #2c2c2c; }
    </style>
  </head>
  <body>
    <!-- Login Screen -->
    <div id="login-screen" class="login-wrap">
      <div class="login-box">
        <h1>Blog Admin</h1>
        <p>Enter your password to manage blog posts.</p>
        <div id="login-msg" class="msg"></div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="Enter admin password" />
        </div>
        <button class="btn btn-primary" style="width:100%; margin-top:0.5rem;" onclick="doLogin()">Log in</button>
      </div>
    </div>

    <!-- Dashboard -->
    <div id="dashboard" class="dashboard">
      <div class="topbar">
        <h1>Blog Admin</h1>
        <div style="display:flex;gap:0.75rem;align-items:center;">
          <button class="btn btn-primary" onclick="showEditor()">+ New Post</button>
          <button class="btn btn-secondary" onclick="doLogout()">Log out</button>
        </div>
      </div>
      <div class="container">
        <div id="dash-msg" class="msg"></div>
        <h2 style="margin-bottom:1rem;">Published Posts</h2>
        <ul id="post-list" class="post-list">
          <li class="post-item"><span style="color:#888;">Loading...</span></li>
        </ul>
      </div>
    </div>

    <!-- Editor -->
    <div id="editor" class="editor">
      <div class="topbar">
        <h1>New Blog Post</h1>
        <div style="display:flex;gap:0.75rem;align-items:center;">
          <button class="btn btn-secondary" onclick="showDashboard()">Cancel</button>
          <button class="btn btn-primary" id="publish-btn" onclick="doPublish()">Publish</button>
        </div>
      </div>
      <div class="container">
        <div id="editor-msg" class="msg"></div>
        <div class="field">
          <label for="post-title">Title</label>
          <input type="text" id="post-title" placeholder="e.g. Understanding ADHD in Adults" />
        </div>
        <div class="row">
          <div class="field">
            <label for="post-category">Category</label>
            <select id="post-category">
              <option value="ADHD">ADHD</option>
              <option value="DBT">DBT</option>
              <option value="Anxiety & Depression">Anxiety & Depression</option>
              <option value="Therapy & Wellbeing">Therapy & Wellbeing</option>
              <option value="LGBTQ+">LGBTQ+</option>
              <option value="ASD & Autism">ASD & Autism</option>
            </select>
          </div>
          <div class="field">
            <label for="post-readtime">Read Time</label>
            <input type="text" id="post-readtime" placeholder="e.g. 8 min read" value="6 min read" />
          </div>
        </div>
        <div class="field">
          <label for="post-description">Description (for SEO)</label>
          <input type="text" id="post-description" placeholder="150 characters max — shows in Google results" maxlength="160" />
          <div class="help">Keep under 160 characters.</div>
        </div>
        <div class="field">
          <label>Content</label>
          <div class="tab-bar">
            <button class="tab active" onclick="showWriteTab(this)">Write</button>
            <button class="tab" onclick="showPreviewTab(this)">Preview</button>
          </div>
          <textarea id="post-body" placeholder="Write your blog post in Markdown...

## Section Heading

Your paragraph text here.

- Bullet point one
- Bullet point two

**Bold text** and *italic text* work as expected."></textarea>
          <div id="preview-pane" class="preview-pane"></div>
          <div class="help">Use Markdown: ## for headings, **bold**, *italic*, - for bullets.</div>
        </div>
        <div class="field">
          <label>
            <input type="checkbox" id="post-featured" style="width:auto;margin-right:0.5rem;" />
            Featured post (appears larger on blog page)
          </label>
        </div>
      </div>
    </div>

    <script>
      let token = sessionStorage.getItem('admin_token') || '';

      // Auto-login if token exists
      if (token) {
        showDashboard();
      }

      async function doLogin() {
        const pw = document.getElementById('password').value;
        const msg = document.getElementById('login-msg');
        msg.className = 'msg';
        msg.textContent = '';

        if (!pw) {
          msg.className = 'msg error';
          msg.textContent = 'Please enter a password.';
          return;
        }

        try {
          const res = await fetch('/api/admin/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: pw }),
          });
          const data = await res.json();

          if (!res.ok || !data.token) {
            msg.className = 'msg error';
            msg.textContent = data.error || 'Incorrect password.';
            return;
          }

          token = data.token;
          sessionStorage.setItem('admin_token', token);
          showDashboard();
        } catch {
          msg.className = 'msg error';
          msg.textContent = 'Could not connect. Is the site deployed?';
        }
      }

      // Enter key on password field
      document.getElementById('password').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') doLogin();
      });

      function doLogout() {
        token = '';
        sessionStorage.removeItem('admin_token');
        document.getElementById('login-screen').style.display = '';
        document.getElementById('dashboard').classList.remove('active');
        document.getElementById('editor').classList.remove('active');
        document.getElementById('password').value = '';
      }

      async function showDashboard() {
        document.getElementById('login-screen').style.display = 'none';
        document.getElementById('editor').classList.remove('active');
        document.getElementById('dashboard').classList.add('active');
        await loadPosts();
      }

      function showEditor() {
        document.getElementById('dashboard').classList.remove('active');
        document.getElementById('editor').classList.add('active');
        // Reset form
        document.getElementById('post-title').value = '';
        document.getElementById('post-description').value = '';
        document.getElementById('post-body').value = '';
        document.getElementById('post-readtime').value = '6 min read';
        document.getElementById('post-featured').checked = false;
        document.getElementById('editor-msg').className = 'msg';
      }

      function categoryBadgeClass(cat) {
        const map = {
          'ADHD': 'badge-adhd',
          'DBT': 'badge-dbt',
          'Anxiety & Depression': 'badge-anxiety',
          'Therapy & Wellbeing': 'badge-therapy',
          'LGBTQ+': 'badge-lgbtq',
          'ASD & Autism': 'badge-asd',
        };
        return map[cat] || '';
      }

      async function loadPosts() {
        const list = document.getElementById('post-list');
        list.innerHTML = '<li class="post-item"><span style="color:#888;">Loading...</span></li>';

        try {
          const res = await fetch('/api/admin/list-posts', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`,
            },
          });

          if (res.status === 401) {
            doLogout();
            return;
          }

          const data = await res.json();
          const posts = data.posts || [];

          if (posts.length === 0) {
            list.innerHTML = '<li class="post-item"><span style="color:#888;">No posts yet.</span></li>';
            return;
          }

          list.innerHTML = posts.map(p => `
            <li class="post-item">
              <div>
                <div class="title">${escHtml(p.title)}</div>
                <div class="meta">${p.date} &middot; <span class="badge ${categoryBadgeClass(p.category)}">${escHtml(p.category)}</span></div>
              </div>
            </li>
          `).join('');
        } catch {
          list.innerHTML = '<li class="post-item"><span style="color:#991b1b;">Failed to load posts. Make sure the site is deployed to Cloudflare.</span></li>';
        }
      }

      async function doPublish() {
        const btn = document.getElementById('publish-btn');
        const msg = document.getElementById('editor-msg');
        msg.className = 'msg';

        const title = document.getElementById('post-title').value.trim();
        const description = document.getElementById('post-description').value.trim();
        const category = document.getElementById('post-category').value;
        const readTime = document.getElementById('post-readtime').value.trim();
        const body = document.getElementById('post-body').value.trim();
        const featured = document.getElementById('post-featured').checked;

        if (!title) { msg.className = 'msg error'; msg.textContent = 'Title is required.'; return; }
        if (!description) { msg.className = 'msg error'; msg.textContent = 'Description is required for SEO.'; return; }
        if (!body) { msg.className = 'msg error'; msg.textContent = 'Post content is required.'; return; }

        btn.disabled = true;
        btn.textContent = 'Publishing...';

        const today = new Date().toISOString().split('T')[0];

        try {
          const res = await fetch('/api/admin/publish', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`,
            },
            body: JSON.stringify({
              title,
              description,
              category,
              readTime,
              date: today,
              featured,
              body,
            }),
          });

          const data = await res.json();

          if (!res.ok) {
            msg.className = 'msg error';
            msg.textContent = data.error || 'Failed to publish.';
            return;
          }

          msg.className = 'msg success';
          msg.textContent = `Published! The site will rebuild in a minute or two. Slug: ${data.slug}`;

          btn.textContent = 'Published!';
          setTimeout(() => showDashboard(), 3000);
        } catch {
          msg.className = 'msg error';
          msg.textContent = 'Could not connect to the server.';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Publish';
        }
      }

      // Simple markdown preview
      function showWriteTab(el) {
        el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('post-body').style.display = '';
        document.getElementById('preview-pane').classList.remove('active');
      }

      function showPreviewTab(el) {
        el.parentElement.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
        document.getElementById('post-body').style.display = 'none';
        const pane = document.getElementById('preview-pane');
        pane.classList.add('active');
        pane.innerHTML = simpleMarkdown(document.getElementById('post-body').value);
      }

      function simpleMarkdown(md) {
        return md
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/^### (.+)$/gm, '<h3>$1</h3>')
          .replace(/^## (.+)$/gm, '<h2>$1</h2>')
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/g, '<em>$1</em>')
          .replace(/^- (.+)$/gm, '<li>$1</li>')
          .replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>')
          .replace(/\n{2,}/g, '</p><p>')
          .replace(/^(?!<[hul])/gm, function(m) { return m ? '<p>' + m : m; })
          .replace(/<p><\/p>/g, '');
      }

      function escHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }
    </script>
  </body>
</html>
